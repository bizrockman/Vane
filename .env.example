# Copy to .env and fill in values. .env is git-ignored.

# orio-search Bearer key (one of the values from ORIO_AUTH_API_KEYS on the
# orio-search side).
TAVILY_API_KEY=

# Base URL of the orio-search instance Vane talks to.
# Default points at the bizrockman dev deployment; override to localhost:8010
# if you're running orio-search locally next to Vane.
TAVILY_BASE_URL=https://llm-websearch.apps.alsdienst.de

# OpenAI key for answer generation.
# Override OPENAI_BASE_URL to point at vllm/Groq/OpenRouter/etc. as needed.
OPENAI_API_KEY=
